<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>圖片變形與圓角控制</title>
<style>
  .image-container {
    display: flex;
    justify-content: space-between;
    align-items: center; 
    width: 100%;
    max-width: 1000px; 
    margin: 50px auto;
    gap: 20px;
  }

  /* 左側圖片：無變形、有圓角 */
  .img-left {
    width: 33%;
    height: 300px; 
    border-radius: 18px; 
    object-fit: cover; 
  }

  /* 中間圖片：正圓形、無變形 */
  .img-center {
    width: 150px; 
    height: 150px; 
    border-radius: 50%; 
    object-fit: cover; 
  }

  /* 右側圖片：有變形 */
  .img-right {
    width: 33%;
    height: 300px; 
  }
</style>
</head>
<body>

<div class="image-container">
  <img class="img-left" src="tower.jpg" alt="左側測試圖">
  
  <img class="img-center" src="middle.jpg" alt="中間測試圖">
  
  <img class="img-right" src="tower.jpg" alt="右側測試圖">
</div>

</body>
</html>
